{
  "name": "yuo-be",
  "private": true,
  "description": "yuo.be website",
  "version": "1.0.0",
  "author": "Reupen Shah",
  "type": "module",
  "license": "0BSD",
  "repository": {
    "type": "git",
    "url": "https://github.com/reupen/yuo.be"
  },
  "scripts": {
    "check": "astro check --minimumFailingSeverity hint",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && npm run purgecss",
    "format:check": "prettier -c .",
    "lint": "eslint --max-warnings 0 .",
    "lint:fix": "npm run lint -- --fix",
    "preview": "astro preview",
    "astro": "astro",
    "purgecss": "purgecss --content dist/**/*.html --css dist/**/*.css --preserve-paths -o ."
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.1",
    "@astrojs/react": "^5.0.6",
    "@date-fns/tz": "^1.4.1",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@playform/compress": "^0.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.8",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "es-toolkit": "^1.46.1",
    "purgecss": "^8.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sass": "^1.97.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@eslint/js": "^10.0.1",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^24.12.4",
    "cssnano": "^7.1.7",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y-x": "^0.2.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "globals": "^17.7.0",
    "html-to-text": "^10.0.0",
    "mime": "^4.1.0",
    "postcss-preset-env": "^11.3.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "rehype-external-links": "^3.0.0",
    "satori": "^0.26.0",
    "schema-dts": "^2.0.0",
    "sharp": "^0.34.5",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "ultrahtml": "^1.6.0"
