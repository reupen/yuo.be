---
import { DownloadList, DownloadListItem } from "@/components"
import DownloadLayout from "@/layouts/DownloadLayout.astro"

const title = "Columns UI SDK"
const description =
  "Columns UI SDK – software development kit for Columns UI panels"
const repo = "columns_ui-sdk"
const links = [
  {
    href: "https://columns-ui-sdk.readthedocs.io/en/latest/",
    label: "Documentation",
  },
]
---

<DownloadLayout
  links={links}
  metaDescription={description}
  repo={repo}
  title={title}
>
  <p>
    The Columns UI SDK allows you to develop panel components for Columns UI.
    See the documentation for more information.
  </p>

  <h2>Downloads</h2>
  <h3>Latest version</h3>
  <DownloadList>
    <DownloadListItem
      filename="columns_ui-sdk-8.1.0.7z"
      label="Version 8.1.0"
    />
  </DownloadList>

  <h3>Previous versions</h3>
  <DownloadList>
    <DownloadListItem
      filename="columns_ui-sdk-8.0.0.7z"
      label="Version 8.0.0"
    />
    <DownloadListItem
      filename="columns_ui-sdk-7.0.0.7z"
      label="Version 7.0.0"
    />
  </DownloadList>
</DownloadLayout>
