---
import columnsUiDemoMp4 from "@/assets/images/columns-ui-demo.mp4"
import { DownloadList, DownloadListItem } from "@/components"
import DownloadLayout from "@/layouts/DownloadLayout.astro"

const title = "Columns UI"
const description =
  "Columns UI – alternative UI for the foobar2000 audio player"
const repo = "columns_ui"
---

<style>
  video {
    width: 100%;
    height: auto;
  }
</style>

<DownloadLayout
  links={[
    {
      href: `https://github.com/reupen/${repo}/releases`,
      label: "Release notes",
    },
    {
      href: "https://columns-ui.readthedocs.io/en/latest/",
      label: "Documentation site",
    },
    {
      href: "https://hydrogenaud.io/index.php/topic,28647.0.html",
      label: "Discussion at the foobar2000 forums",
    },
  ]}
  metaDescription={description}
  repo={repo}
  title={title}
>
  <video
    aria-label="Dark mode, light mode, grouping and smooth scrolling in Columns UI"
    height="1322"
    title="Dark mode, light mode, grouping and smooth scrolling in Columns UI"
    width="2384"
    controls
    muted
    playsinline
  >
    <source src={columnsUiDemoMp4} type="video/mp4" />
  </video>

  <p>
    Columns UI is an open-source user interface for the foobar2000 audio player,
    with interchangeable panels and toolbars.
  </p>
  <p>Its features include:</p>
  <ul>
    <li>a dark mode on Windows 10 and 11</li>
    <li>
      grouping support in the playlist view with variable grouping levels,
      artwork and sticky group headings
    </li>
    <li>optional smooth scrolling in most built-in panels</li>
    <li>inline metadata editing</li>
    <li>
      <a href="https://en.wikipedia.org/wiki/DirectWrite" rel="noopener"
        >DirectWrite text rendering</a
      > in most built-in panels with support for colour emojis, variable fonts and
      dynamic text styling
    </li>
    <li>
      colour management for artwork, and HDR image support in the artwork view
      panel
    </li>
    <li>
      support for SVG icons in the buttons toolbar via <a href="/svg-services"
        >SVG services</a
      >
    </li>
    <li>
      item details and properties panels to view detailed track information
    </li>
  </ul>
  <h2>Requirements</h2>
  <ul>
    <li>Windows 10 or newer</li>
    <li>foobar2000 1.5 or newer</li>
  </ul>

  <h2>Downloads</h2>

  <h3>Latest pre-release version</h3>
  <DownloadList>
    <DownloadListItem
      filename="foo_ui_columns-3.5.0-alpha.3.x86-x64.fb2k-component"
      label="Version 3.5.0 alpha 3"
    >
      <span slot="suffix">– requires Windows 10 or newer</span>
    </DownloadListItem>
  </DownloadList>

  <h3>Latest stable version</h3>
  <DownloadList>
    <DownloadListItem
      filename="foo_ui_columns-3.4.1.x86-x64.fb2k-component"
      label="Version 3.4.1"
    >
      <span slot="suffix"
        >– the last version compatible with Windows 7, 8 and 8.1</span
      >
    </DownloadListItem>
  </DownloadList>

  <p>
    <a href="https://github.com/reupen/columns_ui/releases">
      Reading the release notes is recommended when upgrading.
    </a>
  </p>

